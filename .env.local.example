# ──────────────────────────────────────────────
# Sistema de Gestão Logística — Mestre da Pintura
# Copie para .env.local e preencha os valores reais.
# ──────────────────────────────────────────────

# Banco de dados PostgreSQL (Supabase)
# DATABASE_URL  → pooler (porta 6543) — usado pelo app Next.js em runtime
# DIRECT_URL    → conexão direta (porta 5432) — usado apenas pelo prisma migrate
#
# Supabase: Settings → Database → Connection string
#   Session mode (porta 5432): DIRECT_URL
#   Transaction mode (porta 6543): DATABASE_URL  ← adicionar ?pgbouncer=true
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[SENHA]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[SENHA]@db.[PROJECT-REF].supabase.co:5432/postgres"

# Google Maps — habilitar: Distance Matrix API
# Console: https://console.cloud.google.com/apis/library/distance-matrix-backend.googleapis.com
# Sem esta chave o sistema usa fallback Haversine (distância em linha reta)
GOOGLE_MAPS_API_KEY="sua-chave-aqui"

# JWT — gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="sua-chave-jwt-aqui"

# Lalamove — painel: https://developers.lalamove.com/
# LALAMOVE_SANDBOX="true" para ambiente de testes (não cobra)
LALAMOVE_API_KEY="pk_prod_..."
LALAMOVE_API_SECRET="sk_prod_..."
LALAMOVE_MARKET="BR"
LALAMOVE_SANDBOX="false"

# ──────────────────────────────────────────────
# Citel/Autcom — integração de estoque (Pilar 1)
# Endpoint interno — acesso apenas via rede da empresa ou VPN
# NÃO commitar credenciais reais
# ──────────────────────────────────────────────
CITEL_API_URL="http://<IP-INTERNO>:<PORTA>"
CITEL_LOGIN="<operador-de-integracao>"
CITEL_SENHA="<senha-do-operador>"
CITEL_EMPRESA_BASE="<codigo-empresa-padrao-para-auth>"

# ──────────────────────────────────────────────
# Chave interna — compartilhada entre sistema_logistica e sistema_compras
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# NÃO commitar o valor real
# ──────────────────────────────────────────────
INTERNAL_API_KEY="<gere-uma-chave-segura>"
