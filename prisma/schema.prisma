// Sistema de Gestão Logística — Mestre da Pintura
// Prisma Schema — PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ──────────────────────────────────────────────
// ENUMERAÇÕES
// ──────────────────────────────────────────────

enum Role {
  ADMIN
  OPERATOR   // logística — pode despachar, ver tudo
  SELLER     // vendedor — cria solicitações e cotações
  DRIVER     // motorista — atualiza localização, confirma entregas
}

enum DeliveryType {
  STANDARD   // entrega no dia seguinte, rota interna
  URGENT     // entrega hoje, pode usar Lalamove
  EXCEPTION  // fora das regras normais — requer aprovação
}

enum DeliveryRequestStatus {
  PENDING            // criada, aguardando análise
  AWAITING_ITEMS     // itens sendo separados na loja
  AWAITING_TRANSFER  // aguardando chegada de transferência
  READY              // tudo separado, pronto para despacho
  DISPATCHED         // despachado para rota ou Lalamove
  IN_TRANSIT         // motorista a caminho
  DELIVERED          // entregue ao cliente
  CANCELLED          // cancelada
}

// janela de despacho — determinada no momento da criação pela regra de corte
enum DispatchWindow {
  FIRST_DISPATCH   // criada até 17h30 seg-sex → despacho manhã D+1
  SECOND_DISPATCH  // criada após 17h30 até fim do dia → despacho tarde D+1
  NEXT_DAY         // criada após 12h para entrega D+0 → vai para D+2
  EXPRESS          // Lalamove / urgente — ignora janela de corte
}

// nível de SLA da entrega — complementar a deliveryType
enum SLAType {
  STANDARD   // D+1 — rota interna padrão
  URGENT     // D+0 — frota interna (sujeito ao corte das 12h)
  EXPRESS    // D+0 — via Lalamove/parceiro (ignora corte)
  SCHEDULED  // data específica informada pelo operador
}

enum TransferStatus {
  PENDING      // criada, aguardando aprovação
  APPROVED     // aprovada pelo operador
  PREPARING    // loja de origem separando os itens
  IN_TRANSIT   // a caminho da loja de destino
  RECEIVED     // recebida na loja de destino
  CANCELLED    // cancelada
}

enum TransferPriority {
  ANTICIPATED  // antecipada — programada com antecedência
  ON_ROUTE     // na rota — vai junto com uma entrega existente
  URGENT       // urgente — saída imediata, pode usar Lalamove
}

enum DispatchStatus {
  PENDING     // aguardando atribuição de motorista ou modal
  ASSIGNED    // motorista atribuído
  IN_TRANSIT  // em movimento
  COMPLETED   // entregue / transferência concluída
  FAILED      // falha — devolvido ou não concluído
}

enum DispatchModal {
  INTERNAL_ROUTE  // rota interna com motorista próprio
  LALAMOVE        // despacho via Lalamove
  PARTNER         // parceiro próprio (99, etc.)
  EXCEPTION       // exceção operacional — registra manualmente
}

enum DeviationClassification {
  WITHIN_RULE  // desvio dentro da tolerância configurada
  BELOW_RULE   // cobrado abaixo do sugerido (subsídio — alerta, sem bloqueio)
  ABOVE_RULE   // cobrado acima da tolerância (overcharge — exige justificativa)
}

enum RouteSource {
  GOOGLE_MAPS  // distância via API do Google Maps (ou cache de dados do Google)
  HAVERSINE    // fallback — linha reta (isApproximate = true)
}

enum StockLedgerEntryType {
  SYNC_ERP        // sincronização do ERP (atualiza qtdFisica)
  COMMIT          // estoque comprometido ao criar transferência de saída
  RELEASE         // commit desfeito ao cancelar transferência
  TRANSIT_IN      // transferência de entrada aprovada (incrementa qtdEmTransito no destino)
  TRANSIT_CANCEL  // transferência de entrada cancelada (reverte qtdEmTransito)
  RECONCILE_SEND  // baixa física ao confirmar envio (PREPARING → IN_TRANSIT)
  RECONCILE_RECV  // entrada física ao receber (IN_TRANSIT → RECEIVED)
  DIVERGENCE_ADJ  // ajuste manual após resolução de divergência
  MANUAL          // ajuste manual com justificativa do operador
}

enum DivergenceStatus {
  PENDING_RESOLUTION  // registrada, aguardando resolução do operador (prazo 24h)
  RESOLVED            // resolvida — estoque ajustado e justificado
  VOIDED              // anulada (erro de registro)
}

enum ResolutionType {
  MISSING_PRODUCT   // produto não chegou — ajusta qtdFisica (decremento) + flag reposição
  EXTRA_PRODUCT     // produto a mais chegou — ajusta qtdFisica (incremento)
  OPERATIONAL_ERROR // erro de registro — não altera estoque, apenas justificativa
}

enum AbcClassificationValue {
  A
  B
  C
}

enum DataConfidence {
  HIGH
  MEDIUM
  LOW
}

enum SyncJobType {
  STOCK
  TRANSFERS
  SALES
  PURCHASES
  HISTORY
  ABC
}

enum SyncJobTier {
  FAST_CRITICAL
  FAST_STANDARD
  MEDIUM
  SLOW
}

enum SyncJobStatus {
  RUNNING
  SUCCESS
  PARTIAL
  FAILED
}

enum SyncJobSource {
  API
  CSV
  MANUAL
}

enum AlertType {
  RUPTURA_REDE_SEM_ESTOQUE
  RUPTURA_TRANSFERENCIA_POSSIVEL
  ALERTA_SKU_B
  ABAIXO_MINIMO
  EXCESSO_SUGESTAO
  VENDA_SEM_COBERTURA
  COBERTURA_EM_RISCO
  ENTREGA_DIA_SEGUINTE
  TRANSFER_VENCIDA
  NF_SEM_RECEBIMENTO
  DIVERGENCIA_TRANSFERENCIA
  PEDIDO_COMPRA_VENCIDO
  ITEM_CRITICO_SEM_FATURAR
  FOLLOWUP_VENCIDO
  DIVERGENCIA_COMPRA
}

enum AlertSeverity {
  CRITICAL
  WARNING
  INFO
}

enum AlertStatus {
  PENDING
  IN_PROGRESS
  RESOLVED
  CANCELLED
  SNOOZED
  NEEDS_MANUAL_CONFIRMATION
  CRITICAL_UNRESOLVED
}

enum AlertSlaStatus {
  ON_TRACK
  AT_RISK
  OVERDUE
}

enum AlertActionType {
  CREATE_TRANSFER
  PLACE_PURCHASE_ORDER
  CONFIRM_RECEIPT
  RESOLVE_DIVERGENCE
  CONTACT_SUPPLIER
  LINK_COVERAGE
  REVIEW_STOCK
  INFO_ONLY
}

enum AlertEscalationLevel {
  L1
  L2
  L3
}

enum AlertResolutionType {
  TRANSFER
  PURCHASE
  MANUAL_FIX
  CANCELLED
  AUTO_RESOLVED
}

// ──────────────────────────────────────────────
// LOJAS
// ──────────────────────────────────────────────

model Store {
  id          String  @id @default(cuid())
  code               String  @unique  // 067, 131, 132, 173, 191
  codigoEmpresaCitel String?          // código da empresa no Citel/Autcom (ex: "1", "2")
  name        String
  address     String
  city        String  @default("São Paulo")
  state       String  @default("SP")
  lat         Float
  lng         Float
  phone       String?
  active      Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users                  User[]
  deliveryRequests       DeliveryRequest[]    @relation("StoreDeliveries")
  orderRequests          DeliveryRequest[]    @relation("OrderStoreDeliveries")
  invoiceRequests        DeliveryRequest[]    @relation("InvoiceStoreDeliveries")
  freightQuotes          FreightQuote[]
  transfersFrom          Transfer[]           @relation("TransferFrom")
  transfersTo            Transfer[]           @relation("TransferTo")
  dispatches             Dispatch[]
  drivers                Driver[]
  auditConfigs           AuditConfig[]
  stockLedgers           StockLedger[]
  divergencesResponsible TransferDivergence[] @relation("DivergenceResponsibleStore")
  abcClassifications     AbcClassification[]
  controlTowerAlerts     ControlTowerAlert[]

  @@map("stores")
}

// ──────────────────────────────────────────────
// USUÁRIOS
// ──────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role
  storeId   String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store             Store             @relation(fields: [storeId], references: [id])
  deliveryRequests  DeliveryRequest[]
  freightQuotes     FreightQuote[]
  dispatches        Dispatch[]        @relation("DispatchedBy")
  transfersRequested Transfer[]       @relation("TransferRequestedBy")
  transfersApproved  Transfer[]       @relation("TransferApprovedBy")
  auditJustifications  FreightAudit[]       @relation("AuditJustifiedBy")
  auditSales           FreightAudit[]       @relation("AuditSeller")
  divergencesResolved  TransferDivergence[] @relation("DivergenceResolvedBy")
  alertsOwned          ControlTowerAlert[] @relation("AlertOwner")

  @@map("users")
}

// ──────────────────────────────────────────────
// TABELA DE FRETE POR ZONA
// ──────────────────────────────────────────────

model FreightZone {
  id            String  @id @default(cuid())
  name          String  // Ex: "Zona 1 — até 3 km"
  minKm         Float
  maxKm         Float?  // null = sem limite superior (sob consulta)
  basePrice     Float   // valor em R$
  urgentFactor  Float   @default(1.8)  // multiplicador para urgente
  underConsultation Boolean @default(false) // acima de 20km
  active        Boolean @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  freightQuotes FreightQuote[]

  @@map("freight_zones")
}

// ──────────────────────────────────────────────
// COTAÇÃO DE FRETE
// ──────────────────────────────────────────────

model FreightQuote {
  id              String       @id @default(cuid())
  storeId         String
  originAddress   String
  originLat       Float
  originLng       Float
  destAddress     String
  destLat         Float
  destLng         Float
  distanceKm      Float
  zoneId          String?
  suggestedPrice  Float
  isUrgent        Boolean      @default(false)
  urgentFactor    Float?
  estimatedDays   Int          @default(1)  // 1 = amanhã, 0 = hoje
  durationMinutes Float?                    // duração real de rota em minutos (Google Maps)
  isApproximate   Boolean      @default(false) // true = distância via Haversine (fallback)
  deliveryType    DeliveryType
  createdById     String
  createdAt       DateTime     @default(now())

  store           Store           @relation(fields: [storeId], references: [id])
  zone            FreightZone?    @relation(fields: [zoneId], references: [id])
  createdBy       User            @relation(fields: [createdById], references: [id])
  deliveryRequest DeliveryRequest?

  @@map("freight_quotes")
}

// ──────────────────────────────────────────────
// SOLICITAÇÃO DE ENTREGA
// ──────────────────────────────────────────────

model DeliveryRequest {
  id              String                @id @default(cuid())

  // Identificação pelo Pedido (PD) — fluxo principal
  orderNumber     String?               // número do PD no ERP
  orderStoreId    String?               // loja que gerou o PD
  // NF vinculada depois, quando emitida pelo CD
  invoiceNumber   String?               // NF — preenchida após emissão
  invoiceStoreId  String?               // loja emissora da NF (geralmente CD/132)

  storeId         String                // loja que fez a solicitação
  sellerId        String
  // dados do destinatário (sempre preenchidos pelo vendedor)
  customerId      String?
  customerName    String
  customerPhone   String?
  customerDoc     String?
  // endereço de entrega
  deliveryAddress String
  deliveryComplement String?
  deliveryCity    String?
  deliveryLat     Float?
  deliveryLng     Float?
  // janela de entrega
  deliveryWindowStart String?           // ex: "08:00"
  deliveryWindowEnd   String?           // ex: "12:00"
  // controle
  status          DeliveryRequestStatus @default(PENDING)
  deliveryType    DeliveryType          @default(STANDARD)
  isComplete      Boolean               @default(false)
  freightQuoteId  String?               @unique
  chargedFreight  Float?
  totalValue      Float?
  notes           String?
  scheduledFor    DateTime?
  // janela de despacho — regra de corte 17h30
  dispatchWindow        DispatchWindow?    // calculada na criação; EXPRESS ignora corte
  cutoffWarningShownAt  DateTime?          // quando o aviso de corte foi exibido
  cutoffApprovedBy      String?            // userId do gestor que aprovou exceção
  cutoffApprovalReason  String?            // motivo informado pelo vendedor ao solicitar exceção
  // SLA e corte same-day (12h00)
  slaType               SLAType           @default(STANDARD)
  sameDayRequested      Boolean           @default(false) // vendedor solicitou entrega hoje após 12h
  sameDayApprovedBy     String?           // userId do gestor que aprovou a exceção same-day
  sameDayApprovalReason String?           // motivo da exceção informado pelo vendedor
  sameDayRequestedAt    DateTime?         // quando o pedido de exceção foi feito
  // rastreio de tentativas de vínculo automático PD → NF
  nfLinkLastAttemptAt DateTime?         // quando foi a última tentativa
  nfLinkAttemptCount  Int      @default(0) // quantas tentativas já foram feitas
  nfLinkError         String?            // PARTIAL_BILLING | MULTIPLE_NF | API_ERROR
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  store        Store          @relation("StoreDeliveries",      fields: [storeId],        references: [id])
  orderStore   Store?         @relation("OrderStoreDeliveries", fields: [orderStoreId],   references: [id])
  invoiceStore Store?         @relation("InvoiceStoreDeliveries", fields: [invoiceStoreId], references: [id])
  seller       User           @relation(fields: [sellerId], references: [id])
  freightQuote FreightQuote?  @relation(fields: [freightQuoteId], references: [id])
  items        DeliveryItem[]
  transfers    Transfer[]
  dispatch     Dispatch?
  audit        FreightAudit?

  @@unique([orderNumber, orderStoreId])
  @@map("delivery_requests")
}

// ──────────────────────────────────────────────
// ITENS DA SOLICITAÇÃO
// ──────────────────────────────────────────────

model DeliveryItem {
  id                String  @id @default(cuid())
  deliveryRequestId String
  productCode       String
  productName       String
  quantity          Float
  unit              String  @default("UN")
  // disponibilidade por loja
  availableAtStore  Boolean @default(true)
  sourceStoreId     String?  // qual loja tem o item (pode ser diferente da loja de origem)
  transferId        String?  // se precisou de transferência
  createdAt         DateTime @default(now())

  deliveryRequest DeliveryRequest @relation(fields: [deliveryRequestId], references: [id], onDelete: Cascade)

  @@map("delivery_items")
}

// ──────────────────────────────────────────────
// TRANSFERÊNCIA (entidade de domínio principal)
// ──────────────────────────────────────────────

model Transfer {
  id                String           @id @default(cuid())
  // referência à solicitação de entrega (pode ser nula — transferência autônoma)
  deliveryRequestId String?
  fromStoreId       String
  toStoreId         String
  priority          TransferPriority
  status            TransferStatus   @default(PENDING)
  requestedById     String?
  approvedById      String?
  // datas do ciclo de vida
  requestedAt       DateTime         @default(now())
  approvedAt        DateTime?
  preparingAt       DateTime?
  dispatchedAt      DateTime?
  receivedAt        DateTime?
  cancelledAt       DateTime?
  updatedAt         DateTime         @updatedAt
  // contexto
  notes             String?
  internalNotes     String?  // notas do operador, não visíveis ao vendedor
  estimatedArrival  DateTime?
  // NF emitida no Citel — quando preenchida, o Citel passa a controlar a reserva.
  // citelTakesOver() só roda quando este campo é definido pela primeira vez.
  nfCitelNumero     String?
  nfCitelEmitidaAt  DateTime?
  // controle de divergência no recebimento
  hasDivergence     Boolean  @default(false)
  divergenceCount   Int      @default(0)

  deliveryRequest DeliveryRequest?    @relation(fields: [deliveryRequestId], references: [id])
  fromStore       Store               @relation("TransferFrom", fields: [fromStoreId], references: [id])
  toStore         Store               @relation("TransferTo", fields: [toStoreId], references: [id])
  requestedBy     User?               @relation("TransferRequestedBy", fields: [requestedById], references: [id])
  approvedBy      User?               @relation("TransferApprovedBy", fields: [approvedById], references: [id])
  items           TransferItem[]
  dispatch        Dispatch?           @relation("TransferDispatch")
  history         TransferHistory[]
  divergences     TransferDivergence[]

  @@map("transfers")
}

// histórico de status das transferências para rastreabilidade
model TransferHistory {
  id           String         @id @default(cuid())
  transferId   String
  fromStatus   TransferStatus?
  toStatus     TransferStatus
  changedById  String?
  notes        String?
  createdAt    DateTime       @default(now())

  transfer Transfer @relation(fields: [transferId], references: [id])

  @@map("transfer_history")
}

// ──────────────────────────────────────────────
// ITENS DA TRANSFERÊNCIA
// ──────────────────────────────────────────────

model TransferItem {
  id           String  @id @default(cuid())
  transferId   String
  productCode  String
  productName  String
  quantity     Float   // quantidade solicitada
  unit         String  @default("UN")
  sentQty      Float?  // quantidade enviada (pode ser menor)
  receivedQty  Float?  // quantidade confirmada no recebimento
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  transfer    Transfer             @relation(fields: [transferId], references: [id], onDelete: Cascade)
  divergences TransferDivergence[]

  @@map("transfer_items")
}

// ──────────────────────────────────────────────
// DESPACHO
// ──────────────────────────────────────────────

model Dispatch {
  id                String        @id @default(cuid())
  // despacho pode ser de uma entrega OU de uma transferência
  deliveryRequestId String?       @unique
  transferId        String?       @unique
  storeId           String        // loja que despacha
  modal             DispatchModal
  status            DispatchStatus @default(PENDING)
  driverId          String?
  routeId           String?
  // financeiro
  estimatedCost     Float?   // custo previsto ao despachar
  actualCost        Float?   // custo real após conclusão
  // referências externas
  lalamoveOrderId   String?
  spokeRouteId      String?  // ID da rota no Spoke
  partnerRef        String?  // referência de parceiro (99, etc.)
  // controle
  dispatchedById    String
  notes             String?
  dispatchedAt      DateTime?
  completedAt       DateTime?
  failedAt          DateTime?
  failureReason     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  deliveryRequest DeliveryRequest? @relation(fields: [deliveryRequestId], references: [id])
  transfer        Transfer?        @relation("TransferDispatch", fields: [transferId], references: [id])
  store           Store            @relation(fields: [storeId], references: [id])
  driver          Driver?          @relation(fields: [driverId], references: [id])
  route           Route?           @relation(fields: [routeId], references: [id])
  dispatchedBy    User             @relation("DispatchedBy", fields: [dispatchedById], references: [id])
  lalamoveOrder   LalamoveOrder?
  audit           FreightAudit?

  @@map("dispatches")
}

// ──────────────────────────────────────────────
// MOTORISTAS
// ──────────────────────────────────────────────

model Driver {
  id           String  @id @default(cuid())
  name         String
  phone        String
  storeId      String
  vehicleType  String? // moto, carro, van, caminhão
  licensePlate String?
  active       Boolean @default(true)
  available    Boolean @default(true)  // disponível para nova rota?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  store      Store           @relation(fields: [storeId], references: [id])
  dispatches Dispatch[]
  locations  DriverLocation[]
  routes     Route[]

  @@map("drivers")
}

// ──────────────────────────────────────────────
// LOCALIZAÇÃO DOS MOTORISTAS (rastreamento)
// ──────────────────────────────────────────────

model DriverLocation {
  id        String  @id @default(cuid())
  driverId  String
  lat       Float
  lng       Float
  speed     Float?   // km/h
  heading   Float?   // graus (0-360)
  accuracy  Float?   // metros
  source    String  @default("MANUAL") // MANUAL, APP, GPS_TRACKER
  timestamp DateTime @default(now())

  driver Driver @relation(fields: [driverId], references: [id])

  @@index([driverId, timestamp])
  @@map("driver_locations")
}

// ──────────────────────────────────────────────
// ROTAS INTERNAS
// ──────────────────────────────────────────────

model Route {
  id          String   @id @default(cuid())
  name        String?
  driverId    String
  date        DateTime
  status      String   @default("ACTIVE")  // ACTIVE, COMPLETED, CANCELLED
  spokeRouteId String?  // ID no sistema Spoke para sincronização
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  driver     Driver     @relation(fields: [driverId], references: [id])
  dispatches Dispatch[]

  @@map("routes")
}

// ──────────────────────────────────────────────
// INTEGRAÇÃO LALAMOVE
// ──────────────────────────────────────────────

model LalamoveOrder {
  id              String  @id @default(cuid())
  dispatchId      String  @unique
  // IDs do Lalamove
  lalamoveOrderId String  @unique
  quotationId     String?
  // status mapeado para interno
  status          String  // PENDING, ASSIGNING_DRIVER, ON_GOING, PICKED_UP, COMPLETED, CANCELLED, REJECTED, EXPIRED
  internalStatus  DispatchStatus
  // dados do motorista do Lalamove
  driverName      String?
  driverPhone     String?
  driverPlate     String?
  driverPhoto     String?
  shareLink       String?   // link de rastreamento público
  // financeiro
  estimatedPrice  Float?
  finalPrice      Float?
  currency        String  @default("BRL")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  dispatch Dispatch        @relation(fields: [dispatchId], references: [id])
  events   LalamoveEvent[]

  @@map("lalamove_orders")
}

// eventos recebidos via webhook do Lalamove
model LalamoveEvent {
  id                  String   @id @default(cuid())
  lalamoveOrderId     String
  externalOrderId     String   // ID da ordem no Lalamove
  eventType           String   // ORDER_STATUS_UPDATED, DRIVER_ASSIGNED, etc.
  rawPayload          Json     // payload bruto do webhook
  processedAt         DateTime?
  processingError     String?
  createdAt           DateTime @default(now())

  order LalamoveOrder @relation(fields: [lalamoveOrderId], references: [id])

  @@map("lalamove_events")
}

// ──────────────────────────────────────────────
// CONFIGURAÇÃO DE AUDITORIA
// Política de tolerância separada do dado auditado.
// storeId = null → configuração global.
// Configuração específica por loja tem precedência.
// ──────────────────────────────────────────────

model AuditConfig {
  id               String   @id @default(cuid())
  storeId          String?  // null = configuração global
  tolerancePercent Float    @default(15) // % de desvio permitido sem justificativa
  description      String?
  active           Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  store Store? @relation(fields: [storeId], references: [id])

  @@map("audit_configs")
}

// ──────────────────────────────────────────────
// AUDITORIA DE FRETE
// ──────────────────────────────────────────────

model FreightAudit {
  id                String        @id @default(cuid())
  deliveryRequestId String?       @unique
  dispatchId        String?       @unique
  invoiceNumber     String?
  storeId           String
  // 4 valores para análise de desvios
  suggestedFreight  Float?   // calculado pelo sistema
  chargedFreight    Float?   // cobrado do cliente pelo vendedor
  estimatedCost     Float?   // custo previsto ao despachar
  actualCost        Float?   // custo real após conclusão
  // modal usado
  modal             DispatchModal?
  deliveryType      DeliveryType?
  distanceKm        Float?
  // desvios calculados
  freightDeviation  Float?   // chargedFreight - suggestedFreight
  costDeviation     Float?   // actualCost - estimatedCost
  // classificação e controle de desvio
  deviationPercent        Float?                    // (chargedFreight - suggestedFreight) / suggestedFreight * 100
  deviationClassification DeviationClassification?  // classificação automática
  tolerancePercent        Float?                    // tolerância vigente no momento da criação
  justificationRequired   Boolean @default(false)   // true = desvio exige justificativa
  justification           String?                   // texto da justificativa
  justifiedById           String?                   // quem justificou
  justifiedAt             DateTime?                 // quando justificou
  // contexto da rota
  routeSource             RouteSource?              // fonte da distância (para % de fallback)
  durationMinutes         Float?                    // duração da rota no momento da cotação
  // para KPIs — desnormalizado para evitar joins
  sellerId                String?                   // vendedor da solicitação
  totalValue              Float?                    // valor total da NF (para % sobre faturamento)
  // contexto
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  deliveryRequest DeliveryRequest? @relation(fields: [deliveryRequestId], references: [id])
  dispatch        Dispatch?        @relation(fields: [dispatchId], references: [id])
  justifiedBy     User?            @relation("AuditJustifiedBy", fields: [justifiedById], references: [id])
  seller          User?            @relation("AuditSeller", fields: [sellerId], references: [id])

  @@map("freight_audits")
}

// ──────────────────────────────────────────────
// CACHE DE ROTAS (Google Maps Distance Matrix)
// ──────────────────────────────────────────────

model RouteCache {
  id          String   @id @default(cuid())
  // chave de lookup: coordenadas arredondadas a 4 casas (~11m) + período do dia
  cacheKey    String   @unique // "{oLat4dp}_{oLng4dp}_{dLat4dp}_{dLng4dp}_{MORNING|AFTERNOON|EVENING}"
  originLat   Float
  originLng   Float
  destLat     Float
  destLng     Float
  distanceKm  Float
  durationMin Float    // duração em minutos
  source      String   @default("GOOGLE_MAPS")
  fetchedAt   DateTime @default(now())
  expiresAt   DateTime // TTL dinâmico: ≤5km=7d · 5-15km=15d · >15km=30d

  @@index([cacheKey])
  @@map("route_cache")
}

// ──────────────────────────────────────────────
// CONFIGURAÇÕES DO SISTEMA
// ──────────────────────────────────────────────

model SystemConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  type      String   @default("string") // string, number, boolean, json
  label     String?
  updatedAt DateTime @updatedAt

  @@map("system_configs")
}

// ──────────────────────────────────────────────
// RAZÃO DE ESTOQUE (STOCK LEDGER)
//
// Uma linha por (loja, produto). Mantém três contadores:
//   qtdFisica       — o que o ERP diz que tem (fonte: sync_estoque)
//   qtdComprometida — reservado para saídas aprovadas ainda não despachadas
//   qtdEmTransito   — a caminho desta loja, ainda não chegou
//
// qtdDisponivel = qtdFisica - qtdComprometida (calculado na aplicação)
//
// O ERP é fonte de verdade para qtdFisica.
// O sistema_logistica é fonte de verdade para qtdComprometida e qtdEmTransito.
// ──────────────────────────────────────────────

model StockLedger {
  id              String    @id @default(cuid())
  storeId         String
  productCode     String
  productName     String
  qtdFisica       Float     @default(0)
  qtdComprometida Float     @default(0)
  qtdEmTransito   Float     @default(0)
  version         Int       @default(0)  // controle de concorrência otimista
  syncedAt        DateTime?              // última sincronização do ERP
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  store       Store              @relation(fields: [storeId], references: [id])
  entries     StockLedgerEntry[]
  divergences TransferDivergence[]

  @@unique([storeId, productCode])
  @@index([storeId])
  @@index([productCode])
  @@map("stock_ledgers")
}

// ──────────────────────────────────────────────
// ENTRADAS DO RAZÃO (AUDIT LOG)
// Registra cada evento que alterou qualquer contador
// do StockLedger. Responde "por que está assim?"
// ──────────────────────────────────────────────

model StockLedgerEntry {
  id            String               @id @default(cuid())
  ledgerId      String
  type          StockLedgerEntryType
  qty           Float                // positivo = incremento, negativo = decremento
  field         String               // "qtdFisica" | "qtdComprometida" | "qtdEmTransito"
  referenceId   String?              // ID da transferência ou despacho que gerou o evento
  referenceType String?              // "transfer" | "dispatch" | "manual"
  notes         String?
  createdById   String?
  createdAt     DateTime             @default(now())

  ledger StockLedger @relation(fields: [ledgerId], references: [id])

  @@index([ledgerId, createdAt])
  @@index([referenceId])
  @@map("stock_ledger_entries")
}

// ──────────────────────────────────────────────
// DIVERGÊNCIA DE TRANSFERÊNCIA
//
// Criada quando sentQty != receivedQty no recebimento.
// Bloqueia o avanço automático da solicitação para READY
// até que um operador resolva e justifique.
// ──────────────────────────────────────────────

model TransferDivergence {
  id                  String           @id @default(cuid())
  transferId          String
  transferItemId      String
  ledgerId            String           // ledger da loja destino (onde o estoque chega)
  productCode         String
  productName         String
  sentQty             Float
  receivedQty         Float
  divergenceQty       Float            // sentQty - receivedQty (positivo = faltou, negativo = sobrou)
  status              DivergenceStatus @default(PENDING_RESOLUTION)
  responsibleStoreId  String           // loja responsável pela resolução (padrão: destino)
  deadline            DateTime         // prazo para resolução (padrão: 24h após criação)
  resolutionType      ResolutionType?  // obrigatório ao resolver; null enquanto PENDING_RESOLUTION
  resolution          String?          // descrição da resolução pelo operador
  resolvedById        String?
  resolvedAt          DateTime?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  transfer          Transfer     @relation(fields: [transferId], references: [id])
  transferItem      TransferItem @relation(fields: [transferItemId], references: [id])
  ledger            StockLedger  @relation(fields: [ledgerId], references: [id])
  responsibleStore  Store        @relation("DivergenceResponsibleStore", fields: [responsibleStoreId], references: [id])
  resolvedBy        User?        @relation("DivergenceResolvedBy", fields: [resolvedById], references: [id])

  @@map("transfer_divergences")
}

// ──────────────────────────────────────────────
// LOG DE DECISÃO DE FRETE (auditoria e otimização futura)
// ──────────────────────────────────────────────

model FreightDecisionLog {
  id                String   @id @default(cuid())
  storeId           String
  deliveryRequestId String?
  selectedMode      String   // "INTERNAL" | "LALAMOVE"
  selectedVehicle   String   // InternalVehicleType | LalamoveServiceType
  driverId          String?
  distanceKm        Float
  durationMin       Float
  internalCost      Float
  lalamoveCost      Float?
  suggestedPrice    Float
  decisionReason    String
  isUrgent          Boolean
  isApproximate     Boolean
  totalWeightKg     Float
  totalLatas        Int?
  createdAt         DateTime @default(now())

  @@map("freight_decision_logs")
}

model AbcClassification {
  id                 String                 @id @default(cuid())
  storeId            String
  productCode        String
  productName        String
  classification     AbcClassificationValue
  source             String                 @default("MANUAL")
  isManualOverride   Boolean                @default(false)
  minStock           Float?
  maxStock           Float?
  coverageDaysTarget Int                    @default(30)
  avgDailySales      Float?
  coverageDaysActual Float?
  coverageUpdatedAt  DateTime?
  calculatedAt       DateTime?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  store Store @relation(fields: [storeId], references: [id])

  @@unique([storeId, productCode])
  @@index([storeId])
  @@map("abc_classifications")
}

model CitelSyncJob {
  id               String         @id @default(cuid())
  type             SyncJobType
  tier             SyncJobTier
  status           SyncJobStatus  @default(RUNNING)
  source           SyncJobSource  @default(API)
  dataConfidence   DataConfidence @default(HIGH)
  recordsProcessed Int            @default(0)
  errors           Int            @default(0)
  startedAt        DateTime       @default(now())
  finishedAt       DateTime?
  errorDetail      String?

  @@index([type, status])
  @@index([type, startedAt])
  @@map("citel_sync_jobs")
}

model ControlTowerAlert {
  id                 String                @id @default(cuid())
  type               AlertType
  severity           AlertSeverity
  storeId            String
  ownerId            String
  notifiedUserIds    String[]
  actionType         AlertActionType
  slaDeadline        DateTime
  slaStatus          AlertSlaStatus        @default(ON_TRACK)
  status             AlertStatus           @default(PENDING)
  escalationLevel    AlertEscalationLevel?
  escalatedAt        DateTime?
  escalatedToId      String?
  groupKey           String
  suppressedBy       String?
  suppressedAt       DateTime?
  resolvedById       String?
  resolvedAt         DateTime?
  resolutionType     AlertResolutionType?
  resolutionNotes    String?
  resolution         String?
  revalidatedAt      DateTime?
  revalidationResult String?
  dataConfidence     DataConfidence        @default(HIGH)
  whatsappSentAt     DateTime?
  snoozedUntil       DateTime?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  store Store                   @relation(fields: [storeId], references: [id])
  owner User                    @relation("AlertOwner", fields: [ownerId], references: [id])
  items ControlTowerAlertItem[]

  @@index([storeId, status])
  @@index([groupKey])
  @@index([severity, status])
  @@index([slaDeadline])
  @@map("control_tower_alerts")
}

model ControlTowerAlertItem {
  id                     String                  @id @default(cuid())
  alertId                String
  productCode            String
  productName            String
  abcClassification      AbcClassificationValue?
  metricValue            Float
  metricUnit             String
  suggestedSourceStoreId String?
  suggestedSourceQty     Float?
  detail                 Json                    @default("{}")
  createdAt              DateTime                @default(now())

  alert ControlTowerAlert @relation(fields: [alertId], references: [id], onDelete: Cascade)

  @@index([alertId])
  @@map("control_tower_alert_items")
}

// ──────────────────────────────────────────────
// JOB DE VÍNCULO AUTOMÁTICO PD → NF
// ──────────────────────────────────────────────

enum NfLinkJobStatus {
  RUNNING
  SUCCESS
  PARTIAL
  FAILED
}

enum NfLinkJobTrigger {
  CRON
  MANUAL
}

model NfLinkJob {
  id               String           @id @default(cuid())
  status           NfLinkJobStatus  @default(RUNNING)
  trigger          NfLinkJobTrigger @default(CRON)
  requestsChecked  Int              @default(0)  // solicitações avaliadas
  requestsLinked   Int              @default(0)  // NFs vinculadas com sucesso
  requestsPartial  Int              @default(0)  // faturamento parcial encontrado
  requestsMultiNf  Int              @default(0)  // PDs com múltiplas NFs (revisão manual)
  requestsNotFound Int              @default(0)  // PD não encontrado no Citel
  requestsError    Int              @default(0)  // erros de API
  startedAt        DateTime         @default(now())
  finishedAt       DateTime?
  errorDetail      String?

  @@index([status, startedAt])
  @@map("nf_link_jobs")
}
