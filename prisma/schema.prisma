// Sistema de Gestão Logística — Mestre da Pintura
// Prisma Schema — PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ──────────────────────────────────────────────
// ENUMERAÇÕES
// ──────────────────────────────────────────────

enum Role {
  ADMIN
  OPERATOR             // legado — equivale a LOGISTICS_OPERATOR. Mantido por compat até migração completa.
  STOCK_OPERATOR       // operador de estoque — confirma transferências, gerencia separação
  LOGISTICS_OPERATOR   // operador de logística — roteiriza, despacha, supervisiona motoristas
  STORE_LEADER         // líder de loja — aprova transferências e separa mercadorias da SUA loja
  SELLER               // vendedor — cria solicitações e cotações
  BUYER                // comprador — gerencia compras e fornecedores
  DRIVER               // motorista — atualiza localização, confirma entregas
}

enum FreightQuoteStatus {
  DRAFT      // preenchida mas não calculada
  QUOTED     // calculada e salva — válida até fim do dia
  CONVERTED  // virou solicitação de entrega
  EXPIRED    // validade encerrada
  CANCELLED  // cancelada pelo vendedor
}

enum DeliveryType {
  STANDARD   // entrega no dia seguinte, rota interna
  URGENT     // entrega hoje, pode usar Lalamove
  EXCEPTION  // fora das regras normais — requer aprovação
}

enum DeliveryRequestStatus {
  // ── Fase de preparação ──────────────────────────────────
  PENDING            // criada, aguardando análise do operador
  AWAITING_ITEMS     // itens sendo separados na loja
  AWAITING_TRANSFER  // aguardando chegada de transferência de outra loja
  SEPARADO           // itens separados fisicamente — conferido pelo estoquista
  // ── Fase fiscal ─────────────────────────────────────────
  AGUARDANDO_NF      // aguardando emissão da nota fiscal no CD
  NF_EMITIDA         // nota fiscal emitida no sistema Citel
  NF_VINCULADA       // NF vinculada à solicitação pelo sistema
  // ── Fase logística ──────────────────────────────────────
  PRONTO_ROTEIRIZACAO // pronto para roteirização — endereço e NF validados
  ROTEIRIZADO        // incluído em rota pelo operador logístico
  DISPATCHED         // despachado — motorista/Lalamove acionado
  IN_TRANSIT         // motorista em trajeto até o cliente
  DELIVERED          // entregue ao cliente
  // ── Estados especiais ───────────────────────────────────
  OCORRENCIA         // ocorrência registrada — pendente de resolução operacional
  CANCELLED          // cancelada (terminal)
  // ── Compatibilidade (legado) ─────────────────────────────
  READY              // legado: equivale a SEPARADO + NF_VINCULADA no fluxo antigo
}

// janela de despacho — determinada no momento da criação pela regra de corte
enum DispatchWindow {
  FIRST_DISPATCH   // criada até 17h30 seg-sex → despacho manhã D+1
  SECOND_DISPATCH  // criada após 17h30 até fim do dia → despacho tarde D+1
  NEXT_DAY         // criada após 12h para entrega D+0 → vai para D+2
  EXPRESS          // Lalamove / urgente — ignora janela de corte
}

// nível de SLA da entrega — complementar a deliveryType
enum SLAType {
  STANDARD   // D+1 — rota interna padrão
  URGENT     // D+0 — frota interna (sujeito ao corte das 12h)
  EXPRESS    // D+0 — via Lalamove/parceiro (ignora corte)
  SCHEDULED  // data específica informada pelo operador
}

enum TransferStatus {
  PENDING      // criada, aguardando aprovação
  APPROVED     // aprovada pelo operador
  PREPARING    // loja de origem separando os itens
  PREPARED     // separada — aguardando coleta pelo motorista
  IN_TRANSIT   // a caminho da loja de destino
  RECEIVED     // recebida na loja de destino
  CANCELLED    // cancelada
}

enum TransferPriority {
  ANTICIPATED  // antecipada — programada com antecedência
  ON_ROUTE     // na rota — vai junto com uma entrega existente
  URGENT       // urgente — saída imediata, pode usar Lalamove
}

enum DispatchStatus {
  PENDING     // aguardando atribuição de motorista ou modal
  ASSIGNED    // motorista atribuído
  IN_TRANSIT  // em movimento
  COMPLETED   // entregue / transferência concluída
  FAILED      // falha — devolvido ou não concluído
}

enum DispatchModal {
  INTERNAL_ROUTE  // rota interna com motorista próprio
  LALAMOVE        // despacho via Lalamove
  PARTNER         // parceiro próprio (99, etc.)
  EXCEPTION       // exceção operacional — registra manualmente
}

enum DeviationClassification {
  WITHIN_RULE  // desvio dentro da tolerância configurada
  BELOW_RULE   // cobrado abaixo do sugerido (subsídio — alerta, sem bloqueio)
  ABOVE_RULE   // cobrado acima da tolerância (overcharge — exige justificativa)
}

enum RouteSource {
  GOOGLE_MAPS  // distância via API do Google Maps (ou cache de dados do Google)
  HAVERSINE    // fallback — linha reta (isApproximate = true)
}

enum StockLedgerEntryType {
  SYNC_ERP        // sincronização do ERP (atualiza qtdFisica)
  COMMIT          // estoque comprometido ao criar transferência de saída
  RELEASE         // commit desfeito ao cancelar transferência
  TRANSIT_IN      // transferência de entrada aprovada (incrementa qtdEmTransito no destino)
  TRANSIT_CANCEL  // transferência de entrada cancelada (reverte qtdEmTransito)
  RECONCILE_SEND  // baixa física ao confirmar envio (PREPARING → IN_TRANSIT)
  RECONCILE_RECV  // entrada física ao receber (IN_TRANSIT → RECEIVED)
  DIVERGENCE_ADJ  // ajuste manual após resolução de divergência
  MANUAL          // ajuste manual com justificativa do operador
}

enum DivergenceStatus {
  PENDING_RESOLUTION  // registrada, aguardando resolução do operador (prazo 24h)
  RESOLVED            // resolvida — estoque ajustado e justificado
  VOIDED              // anulada (erro de registro)
}

enum ResolutionType {
  MISSING_PRODUCT   // produto não chegou — ajusta qtdFisica (decremento) + flag reposição
  EXTRA_PRODUCT     // produto a mais chegou — ajusta qtdFisica (incremento)
  OPERATIONAL_ERROR // erro de registro — não altera estoque, apenas justificativa
}

enum AbcClassificationValue {
  A
  B
  C
}

enum DataConfidence {
  HIGH
  MEDIUM
  LOW
}

enum SyncJobType {
  STOCK
  TRANSFERS
  SALES
  PURCHASES
  HISTORY
  ABC
}

enum SyncJobTier {
  FAST_CRITICAL
  FAST_STANDARD
  MEDIUM
  SLOW
}

enum SyncJobStatus {
  RUNNING
  SUCCESS
  PARTIAL
  FAILED
}

enum SyncJobSource {
  API
  CSV
  MANUAL
}

enum AlertType {
  RUPTURA_REDE_SEM_ESTOQUE
  RUPTURA_TRANSFERENCIA_POSSIVEL
  ALERTA_SKU_B
  ABAIXO_MINIMO
  EXCESSO_SUGESTAO
  VENDA_SEM_COBERTURA
  COBERTURA_EM_RISCO
  ENTREGA_DIA_SEGUINTE
  TRANSFER_VENCIDA
  NF_SEM_RECEBIMENTO
  DIVERGENCIA_TRANSFERENCIA
  PEDIDO_COMPRA_VENCIDO
  ITEM_CRITICO_SEM_FATURAR
  FOLLOWUP_VENCIDO
  DIVERGENCIA_COMPRA
}

enum AlertSeverity {
  CRITICAL
  WARNING
  INFO
}

enum AlertStatus {
  PENDING
  IN_PROGRESS
  RESOLVED
  CANCELLED
  SNOOZED
  NEEDS_MANUAL_CONFIRMATION
  CRITICAL_UNRESOLVED
}

enum AlertSlaStatus {
  ON_TRACK
  AT_RISK
  OVERDUE
}

enum AlertActionType {
  CREATE_TRANSFER
  PLACE_PURCHASE_ORDER
  CONFIRM_RECEIPT
  RESOLVE_DIVERGENCE
  CONTACT_SUPPLIER
  LINK_COVERAGE
  REVIEW_STOCK
  INFO_ONLY
}

enum AlertEscalationLevel {
  L1
  L2
  L3
}

enum AlertResolutionType {
  TRANSFER
  PURCHASE
  MANUAL_FIX
  CANCELLED
  AUTO_RESOLVED
}

// ──────────────────────────────────────────────
// LOJAS
// ──────────────────────────────────────────────

model Store {
  id          String  @id @default(cuid())
  code               String  @unique  // 067, 131, 132, 173, 191
  codigoEmpresaCitel String?          // código da empresa no Citel/Autcom (ex: "1", "2")
  name        String
  address     String
  city        String  @default("São Paulo")
  state       String  @default("SP")
  lat         Float
  lng         Float
  phone       String?
  active      Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users                  User[]
  deliveryRequests       DeliveryRequest[]    @relation("StoreDeliveries")
  orderRequests          DeliveryRequest[]    @relation("OrderStoreDeliveries")
  invoiceRequests        DeliveryRequest[]    @relation("InvoiceStoreDeliveries")
  freightQuotes          FreightQuote[]
  transfersFrom          Transfer[]           @relation("TransferFrom")
  transfersTo            Transfer[]           @relation("TransferTo")
  dispatches             Dispatch[]
  drivers                Driver[]
  auditConfigs           AuditConfig[]
  stockLedgers           StockLedger[]
  divergencesResponsible TransferDivergence[] @relation("DivergenceResponsibleStore")
  abcClassifications     AbcClassification[]
  controlTowerAlerts     ControlTowerAlert[]

  @@map("stores")
}

// ──────────────────────────────────────────────
// USUÁRIOS
// ──────────────────────────────────────────────

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  password      String
  role          Role
  storeId       String
  citelUserCode String?  @unique     // código operador no Autcom/Citel (ex: "003", "027")
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  store             Store             @relation(fields: [storeId], references: [id])
  deliveryRequests  DeliveryRequest[]
  freightQuotes     FreightQuote[]
  dispatches        Dispatch[]        @relation("DispatchedBy")
  transfersRequested Transfer[]       @relation("TransferRequestedBy")
  transfersApproved  Transfer[]       @relation("TransferApprovedBy")
  auditJustifications  FreightAudit[]       @relation("AuditJustifiedBy")
  auditSales           FreightAudit[]       @relation("AuditSeller")
  divergencesResolved  TransferDivergence[] @relation("DivergenceResolvedBy")
  alertsOwned          ControlTowerAlert[] @relation("AlertOwner")
  notifications        Notification[]
  routingWavesCreated  RoutingWave[]       @relation("RoutingWaveCreatedBy")
  driver               Driver?             @relation("DriverUser")
  deliveryProofs       DeliveryProof[]     @relation("ProofUploadedBy")

  @@map("users")
}

// ──────────────────────────────────────────────
// NOTIFICAÇÕES IN-APP (sininho do header)
// ──────────────────────────────────────────────

model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String    // ver constantes em lib/notifications-types.ts
  title     String
  body      String?
  link      String?   // caminho relativo (ex: /solicitacoes/cuid123)
  metadata  String?   // JSON arbitrário (orderId, transferId, ...)
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
  @@index([createdAt])
  @@map("notifications")
}

// ──────────────────────────────────────────────
// TABELA DE FRETE POR ZONA
// ──────────────────────────────────────────────

model FreightZone {
  id                String  @id @default(cuid())
  name              String  // Ex: "Zona 1 — até 3 km"
  minKm             Float
  maxKm             Float?  // null = sem limite superior (sob consulta)
  basePrice         Float   // valor normal em R$
  expressBasePrice  Float?  // valor express em R$ (override de urgentFactor quando preenchido)
  urgentFactor      Float   @default(1.8)  // legado — usado só quando expressBasePrice = null
  underConsultation Boolean @default(false) // zona "sob consulta" (ex: >30km)
  active            Boolean @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  freightQuotes FreightQuote[]

  @@map("freight_zones")
}

// ──────────────────────────────────────────────
// COTAÇÃO DE FRETE
// ──────────────────────────────────────────────

model FreightQuote {
  id              String              @id @default(cuid())
  storeId         String
  originAddress   String
  originLat       Float
  originLng       Float
  destAddress     String
  destLat         Float
  destLng         Float
  distanceKm      Float
  zoneId          String?
  suggestedPrice  Float
  isUrgent        Boolean             @default(false)
  urgentFactor    Float?
  estimatedDays   Int                 @default(1)
  durationMinutes Float?
  isApproximate   Boolean             @default(false)
  deliveryType    DeliveryType

  // ── campos v2: opção de entrega, status e validade ──────────
  status          FreightQuoteStatus  @default(QUOTED)
  deliveryOption  String?             // "SAME_DAY"|"TOMORROW_FIRST"|"TOMORROW_SECOND"|"EXPRESS"|"SCHEDULED"
  slaType         SLAType?
  dispatchWindow  DispatchWindow?
  city            String?
  state           String?
  quotedAddress   String?             // endereço formatado pelo geocoder
  expiresAt       DateTime?           // fim do dia quando foi criada
  convertedAt     DateTime?
  scheduledFor    DateTime?           // para deliveryOption=SCHEDULED
  cutoffException Boolean             @default(false)
  cutoffExceptionReason String?
  // ────────────────────────────────────────────────────────────

  createdById     String
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  store           Store           @relation(fields: [storeId], references: [id])
  zone            FreightZone?    @relation(fields: [zoneId], references: [id])
  createdBy       User            @relation(fields: [createdById], references: [id])
  deliveryRequest DeliveryRequest?

  @@map("freight_quotes")
}

// ──────────────────────────────────────────────
// SOLICITAÇÃO DE ENTREGA
// ──────────────────────────────────────────────

model DeliveryRequest {
  id              String                @id @default(cuid())

  // Identificação pelo Pedido (PD) — fluxo principal
  orderNumber     String?               // número do PD no ERP
  orderStoreId    String?               // loja que gerou o PD
  // NF vinculada depois, quando emitida pelo CD
  invoiceNumber   String?               // NF — preenchida após emissão
  invoiceStoreId  String?               // loja emissora da NF (geralmente CD/132)

  storeId         String                // loja que fez a solicitação (vendedor cobra zona daqui)
  dispatchStoreId String?               // loja de despacho operacional. true entregaPeloCD → 132; senão → storeId
  entregaPeloCD   Boolean  @default(false) // espelha cabecalho.entregaPeloCD do Citel — define responsável pela separação
  sellerId        String
  // dados do destinatário (sempre preenchidos pelo vendedor)
  customerId      String?
  customerName    String
  customerPhone   String?
  customerDoc     String?
  // endereço de entrega
  deliveryAddress String
  deliveryComplement String?
  deliveryCity    String?
  deliveryLat     Float?
  deliveryLng     Float?
  // janela de entrega
  deliveryWindowStart String?           // ex: "08:00"
  deliveryWindowEnd   String?           // ex: "12:00"
  // controle
  status          DeliveryRequestStatus @default(PENDING)
  deliveryType    DeliveryType          @default(STANDARD)
  isComplete      Boolean               @default(false)
  freightQuoteId  String?               @unique
  chargedFreight  Float?
  totalValue      Float?
  notes           String?
  scheduledFor    DateTime?
  // janela de despacho — regra de corte 17h30
  dispatchWindow        DispatchWindow?    // calculada na criação; EXPRESS ignora corte
  cutoffWarningShownAt  DateTime?          // quando o aviso de corte foi exibido
  cutoffApprovedBy      String?            // userId do gestor que aprovou exceção
  cutoffApprovalReason  String?            // motivo informado pelo vendedor ao solicitar exceção
  // separação física — preenchida pelo estoquista ao marcar SEPARADO
  separatedBy     String?               // userId de quem conferiu a separação
  separatedAt     DateTime?             // quando a separação foi concluída
  // ocorrência — preenchida ao marcar OCORRENCIA
  occurrenceType  String?               // ex: AVARIA, RECUSA_ENTREGA, ENDERECO_ERRADO, AUSENTE
  occurrenceNotes String?               // descrição detalhada da ocorrência
  // SLA e corte same-day (12h00)
  slaType               SLAType           @default(STANDARD)
  sameDayRequested      Boolean           @default(false) // vendedor solicitou entrega hoje após 12h
  sameDayApprovedBy     String?           // userId do gestor que aprovou a exceção same-day
  sameDayApprovalReason String?           // motivo da exceção informado pelo vendedor
  sameDayRequestedAt    DateTime?         // quando o pedido de exceção foi feito
  // bloqueio geográfico — endereço fora de SP
  deliveryState         String?           // estado do endereço de entrega (ex: "SP", "RJ")
  outsideSPApproved     Boolean           @default(false)
  outsideSPApprovedBy   String?           // userId do ADMIN/OPERATOR que autorizou
  outsideSPApprovalReason String?         // justificativa da exceção operacional
  outsideSPApprovedAt   DateTime?         // quando a exceção foi concedida
  // rastreio de tentativas de vínculo automático PD → NF
  nfLinkLastAttemptAt DateTime?         // quando foi a última tentativa
  nfLinkAttemptCount  Int      @default(0) // quantas tentativas já foram feitas
  nfLinkError         String?            // PARTIAL_BILLING | MULTIPLE_NF | API_ERROR
  // totais calculados a partir do snapshot Citel (preenchidos na criação)
  totalWeightKg        Float?            // soma de grossWeight * quantity de todos os itens
  totalLatas           Int?              // quantidade de itens em unidade BD/GL/LT/LA/BR
  // Breakdown detalhado de volumes pra UI: { LA: 3, GL: 2, PAPEL: 1 }.
  // Permite mostrar "3 LA · 2 GL · 1 papelão" em vez de só "5 latas".
  volumeBreakdown      Json?
  hasMissingWeights    Boolean @default(false) // algum item veio sem pesoBruto da Citel
  stockValidationStatus String?          // VALIDATED | PARTIAL | UNAVAILABLE | CITEL_DOWN | PENDING
  stockFetchedAt        DateTime?         // quando o snapshot Citel foi consultado
  // endereços — snapshots no momento da solicitação
  customerAddressSnapshot  String?       // JSON: CitelEndereco do cadastro do cliente
  deliveryAddressSnapshot  String?       // JSON: CitelEndereco efetivo de entrega
  deliveryAddressSource    String?       // ORDER_DELIVERY_ADDRESS | CUSTOMER_MAIN_ADDRESS | MANUAL_OVERRIDE
  deliveryAddressOriginal  String?       // endereço Citel antes de override manual
  deliveryAddressEditedById String?      // userId que fez o override manual
  deliveryAddressEditedAt  DateTime?     // timestamp do override manual
  // status do pedido no ERP no momento da criação
  erpOrderStatus           String?       // status bruto da Citel ex: "APROVADO"
  erpOrderValidationStatus String?       // VALID | CANCELLED | BLOCKED | APPROVAL_PENDING | ALREADY_FULFILLED
  // lock operacional — controle de concorrência (claim system)
  lockedBy       String?   // userId do operador com claim ativo
  lockedByName   String?   // nome denormalizado (evita JOIN na workqueue)
  lockedAt       DateTime? // quando o claim foi feito
  lockExpiresAt  DateTime? // quando expira automaticamente
  lockReason     String?   // SEPARACAO | FISCAL | ROTEIRIZACAO | DESPACHO | OCORRENCIA
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  store        Store          @relation("StoreDeliveries",      fields: [storeId],        references: [id])
  orderStore   Store?         @relation("OrderStoreDeliveries", fields: [orderStoreId],   references: [id])
  invoiceStore Store?         @relation("InvoiceStoreDeliveries", fields: [invoiceStoreId], references: [id])
  seller       User           @relation(fields: [sellerId], references: [id])
  freightQuote FreightQuote?  @relation(fields: [freightQuoteId], references: [id])
  items        DeliveryItem[]
  transfers    Transfer[]
  dispatch     Dispatch?
  audit        FreightAudit?
  statusHistory DeliveryStatusHistory[]
  snapshots     OperationalMetricsSnapshot[]
  erpSyncAlerts ERPSyncAlert[]
  proofs        DeliveryProof[]

  // Unicidade controlada via UNIQUE INDEX PARCIAL no Postgres
  // (CREATE UNIQUE INDEX ... WHERE status <> 'CANCELLED').
  // Ver prisma/migration_partial_unique_order.sql.
  // DRs em CANCELLED não bloqueiam novas inserções — permite recriar quando
  // vendedor cancela e refaz com o mesmo PD.
  @@map("delivery_requests")
}

// ──────────────────────────────────────────────
// COMPROVANTES DE ENTREGA
// Fotos tiradas pelo motorista no momento da entrega (canhoto + material).
// Armazenadas no Supabase Storage. URL fica no campo photoUrl, path no photoPath
// pra possíveis URLs assinadas no futuro.
// ──────────────────────────────────────────────

enum DeliveryProofType {
  RECEIPT     // canhoto assinado da NF
  MATERIAL    // material entregue na obra
  OCCURRENCE  // foto de ocorrência (recusa, dano, etc.)
}

model DeliveryProof {
  id                String            @id @default(cuid())
  deliveryRequestId String
  type              DeliveryProofType
  photoUrl          String            // URL pública (ou base) do Supabase Storage
  photoPath         String            // path interno: "deliveryRequestId/timestamp_type.jpg"
  uploadedById      String?           // User do motorista que fez o upload
  notes             String?
  createdAt         DateTime          @default(now())

  deliveryRequest DeliveryRequest @relation(fields: [deliveryRequestId], references: [id], onDelete: Cascade)
  uploadedBy      User?           @relation("ProofUploadedBy", fields: [uploadedById], references: [id])

  @@index([deliveryRequestId, createdAt])
  @@map("delivery_proofs")
}

// ──────────────────────────────────────────────
// HISTÓRICO DE STATUS DA SOLICITAÇÃO
// Auditoria imutável de todas as transições de status.
// Gerada exclusivamente pela state machine — nunca manualmente.
// ──────────────────────────────────────────────

model DeliveryStatusHistory {
  id                String                 @id @default(cuid())
  deliveryRequestId String
  fromStatus        DeliveryRequestStatus? // null apenas na criação inicial
  toStatus          DeliveryRequestStatus
  changedById       String?                // userId do ator (null = sistema/automação)
  reason            String?                // motivo da transição (opcional)
  metadata          Json?                  // dados extras: occurrenceType, routeId, etc.
  createdAt         DateTime               @default(now())

  deliveryRequest DeliveryRequest @relation(fields: [deliveryRequestId], references: [id], onDelete: Cascade)

  @@index([deliveryRequestId, createdAt])
  @@map("delivery_status_history")
}

// ──────────────────────────────────────────────
// SNAPSHOT DE MÉTRICAS OPERACIONAIS
// Registra o tempo que cada solicitação ficou em
// cada status. Fechado automaticamente pela state
// machine a cada transição — base da observabilidade.
// ──────────────────────────────────────────────

model OperationalMetricsSnapshot {
  id                String                @id @default(cuid())
  deliveryRequestId String
  status            DeliveryRequestStatus // status sendo medido
  enteredAt         DateTime              // quando entrou neste status
  exitedAt          DateTime?             // quando saiu (null = ainda neste status)
  durationSeconds   Int?                  // exitedAt - enteredAt (calculado ao fechar)
  operatorId        String?               // userId de quem acionou esta entrada (null = sistema)
  operatorName      String?               // nome denormalizado
  storeId           String
  slaType           SLAType
  deliveryType      DeliveryType
  dispatchWindow    DispatchWindow?
  createdAt         DateTime              @default(now())

  deliveryRequest DeliveryRequest @relation(fields: [deliveryRequestId], references: [id], onDelete: Cascade)

  @@index([deliveryRequestId, enteredAt])
  @@index([status, enteredAt])              // analytics por status
  @@index([storeId, enteredAt])             // analytics por loja
  @@index([operatorId, enteredAt])          // analytics por operador
  @@index([exitedAt])                       // cleanup de snapshots abertos
  @@map("operational_metrics_snapshots")
}

// ──────────────────────────────────────────────
// ITENS DA SOLICITAÇÃO
// ──────────────────────────────────────────────

model DeliveryItem {
  id                String  @id @default(cuid())
  deliveryRequestId String
  productCode       String
  productName       String  // mantido por compatibilidade — use description para dados Citel
  quantity          Float
  unit              String  @default("UN")
  // snapshot do produto (preenchido pela Citel no momento da criação)
  description       String?          // descricao do produto no Citel
  brand             String?          // marca
  barcode           String?          // codigoBarra (EAN)
  grossWeight       Float?           // pesoBruto em kg por unidade
  totalWeight       Float?           // grossWeight * quantity
  hasMissingWeight  Boolean @default(false) // true se pesoBruto não veio da Citel
  // snapshot de estoque no momento da criação
  availableStock    Float?           // saldoDisponivel na loja no momento da criação
  physicalStock     Float?           // saldoFisico na loja no momento da criação
  daysWithoutSale   Int?             // diasSemVenda
  turnoverClass     String?          // giro (A, B, C)
  stockStatus       String?          // AVAILABLE | RESERVED_ELSEWHERE | UNAVAILABLE | ZERO_STOCK | CITEL_DOWN
  fetchedAt         DateTime?        // quando a Citel foi consultada
  // disponibilidade por loja
  availableAtStore  Boolean @default(true)
  sourceStoreId     String?          // qual loja tem o item
  transferId        String?          // se precisou de transferência
  createdAt         DateTime @default(now())

  deliveryRequest DeliveryRequest @relation(fields: [deliveryRequestId], references: [id], onDelete: Cascade)

  @@map("delivery_items")
}

// ──────────────────────────────────────────────
// TRANSFERÊNCIA (entidade de domínio principal)
// ──────────────────────────────────────────────

model Transfer {
  id                String           @id @default(cuid())
  // referência à solicitação de entrega (pode ser nula — transferência autônoma)
  deliveryRequestId String?
  fromStoreId       String
  toStoreId         String
  priority          TransferPriority
  status            TransferStatus   @default(PENDING)
  requestedById     String?
  approvedById      String?
  // datas do ciclo de vida
  requestedAt       DateTime         @default(now())
  approvedAt        DateTime?
  preparingAt       DateTime?
  preparedAt        DateTime?
  dispatchedAt      DateTime?
  receivedAt        DateTime?
  cancelledAt       DateTime?
  updatedAt         DateTime         @updatedAt
  // contexto
  notes             String?
  internalNotes     String?  // notas do operador, não visíveis ao vendedor
  estimatedArrival  DateTime?
  // NF emitida no Citel — quando preenchida, o Citel passa a controlar a reserva.
  // citelTakesOver() só roda quando este campo é definido pela primeira vez.
  nfCitelNumero     String?
  nfCitelEmitidaAt  DateTime?
  // controle de divergência no recebimento
  hasDivergence     Boolean  @default(false)
  divergenceCount   Int      @default(0)

  deliveryRequest DeliveryRequest?    @relation(fields: [deliveryRequestId], references: [id])
  fromStore       Store               @relation("TransferFrom", fields: [fromStoreId], references: [id])
  toStore         Store               @relation("TransferTo", fields: [toStoreId], references: [id])
  requestedBy     User?               @relation("TransferRequestedBy", fields: [requestedById], references: [id])
  approvedBy      User?               @relation("TransferApprovedBy", fields: [approvedById], references: [id])
  items           TransferItem[]
  dispatch        Dispatch?           @relation("TransferDispatch")
  history         TransferHistory[]
  divergences     TransferDivergence[]

  @@map("transfers")
}

// histórico de status das transferências para rastreabilidade
model TransferHistory {
  id           String         @id @default(cuid())
  transferId   String
  fromStatus   TransferStatus?
  toStatus     TransferStatus
  changedById  String?
  notes        String?
  createdAt    DateTime       @default(now())

  transfer Transfer @relation(fields: [transferId], references: [id])

  @@map("transfer_history")
}

// ──────────────────────────────────────────────
// ITENS DA TRANSFERÊNCIA
// ──────────────────────────────────────────────

model TransferItem {
  id           String  @id @default(cuid())
  transferId   String
  productCode  String
  productName  String
  quantity     Float   // quantidade solicitada
  unit         String  @default("UN")
  sentQty      Float?  // quantidade enviada (pode ser menor)
  receivedQty  Float?  // quantidade confirmada no recebimento
  // Vínculo com PD interno do Autcom (cliente Atual Tintas)
  // Quando preenchido, indica que o Jhow já criou a transferência no ERP.
  linkedCitelPD        String?
  linkedCitelStoreCode String?
  linkedAt             DateTime?
  linkedById           String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  transfer    Transfer             @relation(fields: [transferId], references: [id], onDelete: Cascade)
  divergences TransferDivergence[]

  @@index([linkedCitelPD])
  @@map("transfer_items")
}

// ──────────────────────────────────────────────
// DESPACHO
// ──────────────────────────────────────────────

model Dispatch {
  id                String        @id @default(cuid())
  // despacho pode ser de uma entrega OU de uma transferência
  deliveryRequestId String?       @unique
  transferId        String?       @unique
  storeId           String        // loja que despacha
  modal             DispatchModal
  status            DispatchStatus @default(PENDING)
  driverId          String?
  routeId           String?
  // financeiro
  estimatedCost     Float?   // custo previsto ao despachar
  actualCost        Float?   // custo real após conclusão
  // referências externas
  lalamoveOrderId   String?
  spokeRouteId      String?  // ID da rota no Spoke
  partnerRef        String?  // referência de parceiro (99, etc.)
  // controle
  dispatchedById    String
  notes             String?
  dispatchedAt      DateTime?
  predictedDeliveryAt DateTime?  // ETA calculado no momento do despacho
  completedAt       DateTime?
  failedAt          DateTime?
  failureReason     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  deliveryRequest DeliveryRequest? @relation(fields: [deliveryRequestId], references: [id])
  transfer        Transfer?        @relation("TransferDispatch", fields: [transferId], references: [id])
  store           Store            @relation(fields: [storeId], references: [id])
  driver          Driver?          @relation(fields: [driverId], references: [id])
  route           Route?           @relation(fields: [routeId], references: [id])
  dispatchedBy    User             @relation("DispatchedBy", fields: [dispatchedById], references: [id])
  lalamoveOrder   LalamoveOrder?
  audit           FreightAudit?

  @@map("dispatches")
}

// ──────────────────────────────────────────────
// MOTORISTAS
// ──────────────────────────────────────────────

model Driver {
  id            String  @id @default(cuid())
  name          String
  phone         String
  email         String?  // necessário pra criar no Spoke
  storeId       String
  vehicleType   String? // moto, carro, van, caminhão
  // Capacidade individual em kg. Quando null, usa VEHICLE_CAPACITY[vehicleType]
  // como default. Permite ter dois "FIORINOs" com capacidades diferentes.
  maxLoadKg     Float?
  licensePlate  String?
  spokeDriverId String?  @unique  // "drivers/abc..." retornado pelo Spoke
  // userId: User com role=DRIVER que faz login no app motorista
  userId        String?  @unique
  active        Boolean @default(true)
  available     Boolean @default(true)  // disponível para nova rota?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  store      Store           @relation(fields: [storeId], references: [id])
  user       User?           @relation("DriverUser", fields: [userId], references: [id])
  dispatches Dispatch[]
  locations  DriverLocation[]
  routes     Route[]

  @@map("drivers")
}

// ──────────────────────────────────────────────
// LOCALIZAÇÃO DOS MOTORISTAS (rastreamento)
// ──────────────────────────────────────────────

model DriverLocation {
  id        String  @id @default(cuid())
  driverId  String
  lat       Float
  lng       Float
  speed     Float?   // km/h
  heading   Float?   // graus (0-360)
  accuracy  Float?   // metros
  source    String  @default("MANUAL") // MANUAL, APP, GPS_TRACKER
  timestamp DateTime @default(now())

  driver Driver @relation(fields: [driverId], references: [id])

  @@index([driverId, timestamp])
  @@map("driver_locations")
}

// ──────────────────────────────────────────────
// ROTAS INTERNAS
// ──────────────────────────────────────────────

model Route {
  id           String   @id @default(cuid())
  name         String?
  driverId     String
  date         DateTime
  status       String   @default("ACTIVE")  // ACTIVE, DISPATCHED, COMPLETED, CANCELLED
  spokeRouteId String?  @unique             // "plans/.../routes/..."
  waveId       String?                      // RoutingWave a que pertence
  // Cache do response do Spoke pra renderizar manifest sem novo round-trip
  manifestJson Json?                        // SpokeRoute completo (stops + ETAs)
  sequenceJson Json?                        // [{ stopPosition, deliveryRequestId, eta }] simplificado
  // Dados pra impressão
  estimatedReturnAt DateTime?
  totalWeightKg     Float?
  stopCount         Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  driver     Driver        @relation(fields: [driverId], references: [id])
  wave       RoutingWave?  @relation(fields: [waveId], references: [id])
  dispatches Dispatch[]

  @@map("routes")
}

// ──────────────────────────────────────────────
// ROUTING WAVE (= Plan no Spoke)
// Representa um lote de pedidos enviados juntos pra otimização.
// Uma wave gera N Routes (uma por motorista incluído).
// ──────────────────────────────────────────────

enum RoutingWaveStatus {
  DRAFT          // criada localmente, ainda não enviada
  SENT           // enviada ao Spoke (Plan criado)
  OPTIMIZED      // otimização concluída
  DISTRIBUTED    // distribuída aos motoristas, Routes criadas
  DISPATCHED     // todos os motoristas saíram
  COMPLETED      // todas entregas concluídas
  FAILED         // erro em algum passo
}

model RoutingWave {
  id              String            @id @default(cuid())
  name            String            // "Manhã 13/05"
  date            DateTime          // dia da operação
  status          RoutingWaveStatus @default(DRAFT)
  spokePlanId     String?           @unique  // "plans/abc"
  // metadados
  notes           String?
  errorMessage    String?           // se status=FAILED
  // estado intermediário do pipeline Spoke (operationId, driverIds, requestIds, etc.)
  metadata        Json?
  // controle
  createdById     String
  createdAt       DateTime          @default(now())
  sentAt          DateTime?
  optimizedAt     DateTime?
  distributedAt   DateTime?
  updatedAt       DateTime          @updatedAt

  createdBy       User              @relation("RoutingWaveCreatedBy", fields: [createdById], references: [id])
  routes          Route[]

  @@index([date, status])
  @@map("routing_waves")
}

// ──────────────────────────────────────────────
// INTEGRAÇÃO LALAMOVE
// ──────────────────────────────────────────────

model LalamoveOrder {
  id              String  @id @default(cuid())
  dispatchId      String  @unique
  // IDs do Lalamove
  lalamoveOrderId String  @unique
  quotationId     String?
  // status mapeado para interno
  status          String  // PENDING, ASSIGNING_DRIVER, ON_GOING, PICKED_UP, COMPLETED, CANCELLED, REJECTED, EXPIRED
  internalStatus  DispatchStatus
  // dados do motorista do Lalamove
  driverName      String?
  driverPhone     String?
  driverPlate     String?
  driverPhoto     String?
  shareLink       String?   // link de rastreamento público
  // financeiro
  estimatedPrice  Float?
  finalPrice      Float?
  currency        String  @default("BRL")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  dispatch Dispatch        @relation(fields: [dispatchId], references: [id])
  events   LalamoveEvent[]

  @@map("lalamove_orders")
}

// eventos recebidos via webhook do Lalamove
model LalamoveEvent {
  id                  String   @id @default(cuid())
  lalamoveOrderId     String
  externalOrderId     String   // ID da ordem no Lalamove
  eventType           String   // ORDER_STATUS_UPDATED, DRIVER_ASSIGNED, etc.
  rawPayload          Json     // payload bruto do webhook
  processedAt         DateTime?
  processingError     String?
  createdAt           DateTime @default(now())

  order LalamoveOrder @relation(fields: [lalamoveOrderId], references: [id])

  @@map("lalamove_events")
}

// ──────────────────────────────────────────────
// CONFIGURAÇÃO DE AUDITORIA
// Política de tolerância separada do dado auditado.
// storeId = null → configuração global.
// Configuração específica por loja tem precedência.
// ──────────────────────────────────────────────

model AuditConfig {
  id               String   @id @default(cuid())
  storeId          String?  // null = configuração global
  tolerancePercent Float    @default(15) // % de desvio permitido sem justificativa
  description      String?
  active           Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  store Store? @relation(fields: [storeId], references: [id])

  @@map("audit_configs")
}

// ──────────────────────────────────────────────
// AUDITORIA DE FRETE
// ──────────────────────────────────────────────

model FreightAudit {
  id                String        @id @default(cuid())
  deliveryRequestId String?       @unique
  dispatchId        String?       @unique
  invoiceNumber     String?
  storeId           String
  // 4 valores para análise de desvios
  suggestedFreight  Float?   // calculado pelo sistema
  chargedFreight    Float?   // cobrado do cliente pelo vendedor
  estimatedCost     Float?   // custo previsto ao despachar
  actualCost        Float?   // custo real após conclusão
  // modal usado
  modal             DispatchModal?
  deliveryType      DeliveryType?
  distanceKm        Float?
  // desvios calculados
  freightDeviation  Float?   // chargedFreight - suggestedFreight
  costDeviation     Float?   // actualCost - estimatedCost
  // classificação e controle de desvio
  deviationPercent        Float?                    // (chargedFreight - suggestedFreight) / suggestedFreight * 100
  deviationClassification DeviationClassification?  // classificação automática
  tolerancePercent        Float?                    // tolerância vigente no momento da criação
  justificationRequired   Boolean @default(false)   // true = desvio exige justificativa
  justification           String?                   // texto da justificativa
  justifiedById           String?                   // quem justificou
  justifiedAt             DateTime?                 // quando justificou
  // contexto da rota
  routeSource             RouteSource?              // fonte da distância (para % de fallback)
  durationMinutes         Float?                    // duração da rota no momento da cotação
  // para KPIs — desnormalizado para evitar joins
  sellerId                String?                   // vendedor da solicitação
  totalValue              Float?                    // valor total da NF (para % sobre faturamento)
  // contexto
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  deliveryRequest DeliveryRequest? @relation(fields: [deliveryRequestId], references: [id])
  dispatch        Dispatch?        @relation(fields: [dispatchId], references: [id])
  justifiedBy     User?            @relation("AuditJustifiedBy", fields: [justifiedById], references: [id])
  seller          User?            @relation("AuditSeller", fields: [sellerId], references: [id])

  @@map("freight_audits")
}

// ──────────────────────────────────────────────
// CACHE DE ROTAS (Google Maps Distance Matrix)
// ──────────────────────────────────────────────

model RouteCache {
  id                   String    @id @default(cuid())
  cacheKey             String    @unique // "{oLat4dp}_{oLng4dp}_{dLat4dp}_{dLng4dp}"
  originLat            Float
  originLng            Float
  destLat              Float
  destLng              Float
  distanceKm           Float
  durationMin          Float     // duração sem trânsito (minutos)
  durationInTrafficMin Float?    // duração com trânsito real (null = não disponível)
  trafficExpiresAt     DateTime? // quando o dado de trânsito expira (10 min após fetch)
  provider             String    @default("GOOGLE_ROUTES") // GOOGLE_ROUTES | HAVERSINE
  fetchedAt            DateTime  @default(now())
  expiresAt            DateTime  // TTL base: 24h

  @@index([cacheKey])
  @@map("route_cache")
}

// ──────────────────────────────────────────────
// CACHE DE GEOCODIFICAÇÃO
// Permanente — endereços raramente mudam de coordenadas.
// ──────────────────────────────────────────────

model GeocodingCache {
  id               String   @id @default(cuid())
  queryHash        String   @unique // SHA-256 da query normalizada (lowercase + trim)
  placeId          String?           // Google Place ID
  formattedAddress String
  street           String?
  streetNumber     String?
  neighborhood     String?           // bairro
  city             String
  state            String
  postalCode       String?
  lat              Float
  lng              Float
  withinSP         Boolean  @default(true)
  provider         String   @default("GOOGLE_GEOCODING") // GOOGLE_GEOCODING | NOMINATIM
  cachedAt         DateTime @default(now())

  @@map("geocoding_cache")
}

// ──────────────────────────────────────────────
// LOG DE USO DA API DO GOOGLE MAPS
// Contagem diária de chamadas — base para controle de custos.
// ──────────────────────────────────────────────

model MapsUsageLog {
  id        String   @id @default(cuid())
  endpoint  String   // COMPUTE_ROUTES | GEOCODE | ROUTE_CACHE_HIT | GEOCODE_CACHE_HIT | HAVERSINE_FALLBACK
  cacheHit  Boolean  @default(false)
  success   Boolean  @default(true)
  storeId   String?
  error     String?
  createdAt DateTime @default(now())

  @@index([endpoint, createdAt])
  @@index([createdAt])
  @@map("maps_usage_logs")
}

// ──────────────────────────────────────────────
// CONFIGURAÇÕES DO SISTEMA
// ──────────────────────────────────────────────

model SystemConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  type      String   @default("string") // string, number, boolean, json
  label     String?
  updatedAt DateTime @updatedAt

  @@map("system_configs")
}

// ──────────────────────────────────────────────
// RAZÃO DE ESTOQUE (STOCK LEDGER)
//
// Uma linha por (loja, produto). Mantém três contadores:
//   qtdFisica       — o que o ERP diz que tem (fonte: sync_estoque)
//   qtdComprometida — reservado para saídas aprovadas ainda não despachadas
//   qtdEmTransito   — a caminho desta loja, ainda não chegou
//
// qtdDisponivel = qtdFisica - qtdComprometida (calculado na aplicação)
//
// O ERP é fonte de verdade para qtdFisica.
// O sistema_logistica é fonte de verdade para qtdComprometida e qtdEmTransito.
// ──────────────────────────────────────────────

model StockLedger {
  id              String    @id @default(cuid())
  storeId         String
  productCode     String
  productName     String
  qtdFisica       Float     @default(0)
  qtdComprometida Float     @default(0)
  qtdEmTransito   Float     @default(0)
  version         Int       @default(0)  // controle de concorrência otimista
  syncedAt        DateTime?              // última sincronização do ERP
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  store       Store              @relation(fields: [storeId], references: [id])
  entries     StockLedgerEntry[]
  divergences TransferDivergence[]

  @@unique([storeId, productCode])
  @@index([storeId])
  @@index([productCode])
  @@map("stock_ledgers")
}

// ──────────────────────────────────────────────
// ENTRADAS DO RAZÃO (AUDIT LOG)
// Registra cada evento que alterou qualquer contador
// do StockLedger. Responde "por que está assim?"
// ──────────────────────────────────────────────

model StockLedgerEntry {
  id            String               @id @default(cuid())
  ledgerId      String
  type          StockLedgerEntryType
  qty           Float                // positivo = incremento, negativo = decremento
  field         String               // "qtdFisica" | "qtdComprometida" | "qtdEmTransito"
  referenceId   String?              // ID da transferência ou despacho que gerou o evento
  referenceType String?              // "transfer" | "dispatch" | "manual"
  notes         String?
  createdById   String?
  createdAt     DateTime             @default(now())

  ledger StockLedger @relation(fields: [ledgerId], references: [id])

  @@index([ledgerId, createdAt])
  @@index([referenceId])
  @@map("stock_ledger_entries")
}

// ──────────────────────────────────────────────
// DIVERGÊNCIA DE TRANSFERÊNCIA
//
// Criada quando sentQty != receivedQty no recebimento.
// Bloqueia o avanço automático da solicitação para READY
// até que um operador resolva e justifique.
// ──────────────────────────────────────────────

model TransferDivergence {
  id                  String           @id @default(cuid())
  transferId          String
  transferItemId      String
  ledgerId            String           // ledger da loja destino (onde o estoque chega)
  productCode         String
  productName         String
  sentQty             Float
  receivedQty         Float
  divergenceQty       Float            // sentQty - receivedQty (positivo = faltou, negativo = sobrou)
  status              DivergenceStatus @default(PENDING_RESOLUTION)
  responsibleStoreId  String           // loja responsável pela resolução (padrão: destino)
  deadline            DateTime         // prazo para resolução (padrão: 24h após criação)
  resolutionType      ResolutionType?  // obrigatório ao resolver; null enquanto PENDING_RESOLUTION
  resolution          String?          // descrição da resolução pelo operador
  resolvedById        String?
  resolvedAt          DateTime?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  transfer          Transfer     @relation(fields: [transferId], references: [id])
  transferItem      TransferItem @relation(fields: [transferItemId], references: [id])
  ledger            StockLedger  @relation(fields: [ledgerId], references: [id])
  responsibleStore  Store        @relation("DivergenceResponsibleStore", fields: [responsibleStoreId], references: [id])
  resolvedBy        User?        @relation("DivergenceResolvedBy", fields: [resolvedById], references: [id])

  @@map("transfer_divergences")
}

// ──────────────────────────────────────────────
// LOG DE DECISÃO DE FRETE (auditoria e otimização futura)
// ──────────────────────────────────────────────

model FreightDecisionLog {
  id                String   @id @default(cuid())
  storeId           String
  deliveryRequestId String?
  selectedMode      String   // "INTERNAL" | "LALAMOVE"
  selectedVehicle   String   // InternalVehicleType | LalamoveServiceType
  driverId          String?
  distanceKm        Float
  durationMin       Float
  internalCost      Float
  lalamoveCost      Float?
  suggestedPrice    Float
  decisionReason    String
  isUrgent          Boolean
  isApproximate     Boolean
  totalWeightKg     Float
  totalLatas        Int?
  createdAt         DateTime @default(now())

  @@map("freight_decision_logs")
}

model AbcClassification {
  id                 String                 @id @default(cuid())
  storeId            String
  productCode        String
  productName        String
  classification     AbcClassificationValue
  source             String                 @default("MANUAL")
  isManualOverride   Boolean                @default(false)
  minStock           Float?
  maxStock           Float?
  coverageDaysTarget Int                    @default(30)
  avgDailySales      Float?
  coverageDaysActual Float?
  coverageUpdatedAt  DateTime?
  calculatedAt       DateTime?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  store Store @relation(fields: [storeId], references: [id])

  @@unique([storeId, productCode])
  @@index([storeId])
  @@map("abc_classifications")
}

model CitelSyncJob {
  id               String         @id @default(cuid())
  type             SyncJobType
  tier             SyncJobTier
  status           SyncJobStatus  @default(RUNNING)
  source           SyncJobSource  @default(API)
  dataConfidence   DataConfidence @default(HIGH)
  recordsProcessed Int            @default(0)
  errors           Int            @default(0)
  startedAt        DateTime       @default(now())
  finishedAt       DateTime?
  errorDetail      String?

  @@index([type, status])
  @@index([type, startedAt])
  @@map("citel_sync_jobs")
}

model ControlTowerAlert {
  id                 String                @id @default(cuid())
  type               AlertType
  severity           AlertSeverity
  storeId            String
  ownerId            String
  notifiedUserIds    String[]
  actionType         AlertActionType
  slaDeadline        DateTime
  slaStatus          AlertSlaStatus        @default(ON_TRACK)
  status             AlertStatus           @default(PENDING)
  escalationLevel    AlertEscalationLevel?
  escalatedAt        DateTime?
  escalatedToId      String?
  groupKey           String
  suppressedBy       String?
  suppressedAt       DateTime?
  resolvedById       String?
  resolvedAt         DateTime?
  resolutionType     AlertResolutionType?
  resolutionNotes    String?
  resolution         String?
  revalidatedAt      DateTime?
  revalidationResult String?
  dataConfidence     DataConfidence        @default(HIGH)
  whatsappSentAt     DateTime?
  snoozedUntil       DateTime?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  store Store                   @relation(fields: [storeId], references: [id])
  owner User                    @relation("AlertOwner", fields: [ownerId], references: [id])
  items ControlTowerAlertItem[]

  @@index([storeId, status])
  @@index([groupKey])
  @@index([severity, status])
  @@index([slaDeadline])
  @@map("control_tower_alerts")
}

model ControlTowerAlertItem {
  id                     String                  @id @default(cuid())
  alertId                String
  productCode            String
  productName            String
  abcClassification      AbcClassificationValue?
  metricValue            Float
  metricUnit             String
  suggestedSourceStoreId String?
  suggestedSourceQty     Float?
  detail                 Json                    @default("{}")
  createdAt              DateTime                @default(now())

  alert ControlTowerAlert @relation(fields: [alertId], references: [id], onDelete: Cascade)

  @@index([alertId])
  @@map("control_tower_alert_items")
}

// ──────────────────────────────────────────────
// ERP SYNC ALERT
// Alerta gerado pelo watcher quando o estado do pedido
// no Citel diverge do snapshot capturado na criação.
// ──────────────────────────────────────────────

model ERPSyncAlert {
  id                String   @id @default(cuid())
  deliveryRequestId String
  orderNumber       String
  storeCode         String
  // alertType: ORDER_CANCELLED | ORDER_ALREADY_INVOICED | ITEM_REMOVED
  //            | ITEM_QUANTITY_CHANGED | DELIVERY_ADDRESS_CHANGED | CUSTOMER_CHANGED
  alertType         String
  // severity: CRITICAL | WARNING | INFO
  severity          String
  oldValue          String?  // JSON — valor antes da mudança
  newValue          String?  // JSON — valor atual
  isResolved        Boolean  @default(false)
  resolvedAt        DateTime?
  resolvedById      String?  // userId de quem resolveu
  detectedAt        DateTime @default(now())

  deliveryRequest DeliveryRequest @relation(fields: [deliveryRequestId], references: [id], onDelete: Cascade)

  @@index([deliveryRequestId, isResolved])
  @@index([orderNumber, isResolved])
  @@index([isResolved, detectedAt])
  @@map("erp_sync_alerts")
}

// ──────────────────────────────────────────────
// JOB DE VÍNCULO AUTOMÁTICO PD → NF
// ──────────────────────────────────────────────

enum NfLinkJobStatus {
  RUNNING
  SUCCESS
  PARTIAL
  FAILED
}

enum NfLinkJobTrigger {
  CRON
  MANUAL
}

model NfLinkJob {
  id               String           @id @default(cuid())
  status           NfLinkJobStatus  @default(RUNNING)
  trigger          NfLinkJobTrigger @default(CRON)
  requestsChecked  Int              @default(0)  // solicitações avaliadas
  requestsLinked   Int              @default(0)  // NFs vinculadas com sucesso
  requestsPartial  Int              @default(0)  // faturamento parcial encontrado
  requestsMultiNf  Int              @default(0)  // PDs com múltiplas NFs (revisão manual)
  requestsNotFound Int              @default(0)  // PD não encontrado no Citel
  requestsError    Int              @default(0)  // erros de API
  startedAt        DateTime         @default(now())
  finishedAt       DateTime?
  errorDetail      String?

  @@index([status, startedAt])
  @@map("nf_link_jobs")
}
