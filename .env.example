# Banco de dados PostgreSQL
DATABASE_URL="postgresql://user:password@localhost:5432/logistica"

# JWT (gere uma string aleatória longa em produção)
JWT_SECRET="sua-chave-secreta-aqui-minimo-32-chars"

# ERP (preencher quando disponível)
ERP_API_URL=""
ERP_API_KEY=""

# Google Maps — Distance Matrix API + Geocoding API
# Ativar em: https://console.cloud.google.com/apis/credentials
# Chave server-side (NÃO colocar NEXT_PUBLIC_ — mantém a chave no servidor)
GOOGLE_MAPS_API_KEY=""

# Lalamove
LALAMOVE_API_KEY=""
LALAMOVE_API_SECRET=""
LALAMOVE_MARKET="BR"
LALAMOVE_SANDBOX="true"  # trocar para false em produção

# Spoke (roteirização interna)
SPOKE_API_URL=""
SPOKE_API_KEY=""
